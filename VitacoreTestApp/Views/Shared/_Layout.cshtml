<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewBag.Title - Mandarine Auction</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet" />
</head>
<body>

    <nav class="navbar navbar-expand-lg navbar-dark bg-warning">
        <div class="container">
            <a class="navbar-brand fw-bold text-dark" href="/Lots/Index">🍊 Mandarine Auction</a>

            <div class="ms-auto d-flex align-items-center gap-2">
                @if (User.Identity?.IsAuthenticated == true)
                {
                    <span class="text-dark me-2">👤 @User.Identity.Name</span>
                    <form method="post" action="/Account/Logout" class="d-inline">
                        @Html.AntiForgeryToken()
                        <button type="submit" class="btn btn-sm btn-outline-dark">Logout</button>
                    </form>
                }
                else
                {
                    <a href="/Account/Login" class="btn btn-sm btn-outline-dark">Login</a>
                    <a href="/Account/Register" class="btn btn-sm btn-dark">Register</a>
                }
            </div>
        </div>
    </nav>

    <main class="py-3">
        @RenderBody()
    </main>

    <footer class="bg-light border-top mt-5 py-3 text-center text-muted small">
        Created as a test application for Vitacore. All rights reserved.
    </footer>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
</body>
</html>